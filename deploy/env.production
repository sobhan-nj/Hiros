# ===========================================
# Resume Analyzer — Production Environment
# ===========================================
# Copy this to /opt/resume-analyzer/.env on the server
# and fill in real values before starting the service.

# Environment
ENVIRONMENT=production

# LLM Provider (openai, gemini, anthropic, avalai, mimo)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# API Keys — set the one matching your LLM_PROVIDER
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
AVALAI_API_KEY=
AVALAI_BASE_URL=https://api.avalai.ir/v1
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Admin — CHANGE THIS from the default dev value
ADMIN_API_KEY=your-secure-admin-key-here

# Analysis auth — set to enable API key requirement on /analyze
# Leave empty for open access (not recommended in production)
ANALYSIS_API_KEY=your-analysis-api-key-here

# CORS — your domain(s), comma-separated
CORS_ALLOWED_ORIGINS=https://hiros.online,https://www.hiros.online

# Database (SQLite — fine for single-server)
DATABASE_URL=sqlite+aiosqlite:///./talent_pool.db

# Talent pool storage
TALENT_POOL_ROOT=./talent-pool

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
SENTRY_SEND_PII=false

# Cloudflare Turnstile (optional — if set, /analyze requires valid token)
TURNSTILE_SECRET_KEY=
